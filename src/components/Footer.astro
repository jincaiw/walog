---
import config from "@/config";
import Socials from "./Socials.astro";
---

<footer class="border-t border-border mt-16">
  <div class="mx-auto max-w-[1120px] px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted-foreground">
    <div>
      <span>&copy; {new Date().getFullYear()} {config.site.author}.</span>
      <span> 用 Astro 构建。</span>
    </div>
    <Socials />
  </div>
</footer>
