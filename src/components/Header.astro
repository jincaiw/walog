---
import { siteConfig } from "@/config";
import ThemeToggle from "@/components/ThemeToggle.astro";
---

<header class="sticky top-0 z-40 bg-[var(--color-bg)]/95 backdrop-blur-sm border-b border-[var(--color-border)] dark:bg-[var(--color-bg-dark)]/95 dark:border-[var(--color-border-dark)]">
  <div class="mx-auto max-w-[1120px] px-4 sm:px-6 flex items-center justify-between h-14">
    <a href="/" class="text-lg font-semibold tracking-tight hover:text-[var(--color-accent)] transition-colors">
      {siteConfig.shortTitle}
    </a>
    <div class="flex items-center gap-1">
      <nav class="hidden md:flex items-center gap-1">
        {
          siteConfig.nav.map((item) => (
            <a
              href={item.href}
              class="px-3 py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] dark:text-[var(--color-text-dark-secondary)] dark:hover:text-[var(--color-accent-light)] transition-colors rounded hover:bg-[var(--color-bg-alt)] dark:hover:bg-[var(--color-bg-alt-dark)]"
            >
              {item.text}
            </a>
          ))
        }
      </nav>
      <ThemeToggle />
      <button id="menu-btn" class="md:hidden p-2 text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] dark:text-[var(--color-text-dark-secondary)] dark:hover:text-[var(--color-accent-light)]" aria-label="菜单" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
  <!-- Mobile nav -->
  <div id="mobile-nav" class="mobile-nav md:hidden">
    <div class="px-4 pb-3 pt-1 space-y-1">
      {
        siteConfig.nav.map((item) => (
          <a
            href={item.href}
            class="block px-3 py-2 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] dark:text-[var(--color-text-dark-secondary)] dark:hover:text-[var(--color-accent-light)] transition-colors rounded hover:bg-[var(--color-bg-alt)] dark:hover:bg-[var(--color-bg-alt-dark)]"
          >
            {item.text}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById("menu-btn")!;
  const mobileNav = document.getElementById("mobile-nav")!;
  menuBtn.addEventListener("click", () => {
    mobileNav.classList.toggle("open");
  });
</script>
