---
export interface Props {
  href: string;
  variant?: "primary" | "secondary";
}

const { href, variant = "secondary" } = Astro.props;
---

<a
  href={href}
  class={`inline-flex items-center px-4 py-2 text-sm font-medium rounded transition-colors ${
    variant === "primary"
      ? "bg-accent text-accent-foreground hover:opacity-90"
      : "border border-border hover:border-accent text-foreground"
  }`}
>
  <slot />
</a>
