---
interface Props {
  href?: string;
  class?: string;
  title?: string;
  "aria-label"?: string;
  id?: string;
}

const { href, class: className, ...attrs } = Astro.props;
---

{
  href ? (
    <a
      href={href.startsWith("http") ? href : href}
      target={href.startsWith("http") ? "_blank" : undefined}
      rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
      class:list={["focus-outline", className]}
      {...attrs}
    >
      <slot />
    </a>
  ) : (
    <button class:list={["focus-outline", className]} {...attrs}>
      <slot />
    </button>
  )
}
