---
export interface Props {
  pageTitle: string;
  pageDesc?: string;
}

const { pageTitle, pageDesc } = Astro.props;
---

<div class="mx-auto max-w-[1120px] px-4 sm:px-6 pt-12 pb-16">
  <header class="mb-10">
    <h1 class="text-3xl font-bold">{pageTitle}</h1>
    {pageDesc && <p class="mt-2 text-muted-foreground">{pageDesc}</p>}
  </header>
  <slot />
</div>
