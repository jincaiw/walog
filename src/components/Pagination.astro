---
import type { Page } from "astro";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronLeftAlias from "@/assets/icons/IconArrowLeft.svg";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

type Props = {
  page: Page;
};

const { page: pageData } = Astro.props;
const { currentPage, lastPage, url } = pageData;

// Astro passes the full URL path in `url.prev`/`url.next`
const prevUrl = url.prev;
const nextUrl = url.next;
---

<nav aria-label="Pagination" class="app-layout mb-12 flex items-center justify-between">
  {prevUrl ? (
    <a
      href={prevUrl}
      class="hover:text-accent hover:border-accent border-border flex items-center gap-2 rounded border px-3 py-2 text-sm font-medium"
      aria-label={t.a11y.goToPreviousPage}
    >
      <IconChevronLeft class="size-4 rtl:-rotate-180" />
      <IconChevronLeftAlias class="size-4 rtl:-rotate-180 sm:hidden" />
      <span class="hidden sm:inline">{t.pagination.prev}</span>
    </a>
  ) : (
    <span />
  )}

  <span class="text-muted-foreground text-sm">
    {t.pagination.page} {currentPage} / {lastPage}
  </span>

  {nextUrl ? (
    <a
      href={nextUrl}
      class="hover:text-accent hover:border-accent border-border flex items-center gap-2 rounded border px-3 py-2 text-sm font-medium"
      aria-label={t.a11y.goToNextPage}
    >
      <span class="hidden sm:inline">{t.pagination.next}</span>
      <IconChevronLeft class="size-4 rotate-180 rtl:rotate-0" />
    </a>
  ) : (
    <span />
  )}
</nav>
