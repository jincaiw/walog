---
export interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;
---

{
  totalPages > 1 && (
    <nav class="flex items-center justify-center gap-2 mt-10" aria-label="分页">
      {currentPage > 1 && (
        <a
          href={currentPage === 2 ? baseUrl : `${baseUrl}/${currentPage - 1}`}
          class="px-3 py-1.5 text-sm border border-[var(--color-border)] dark:border-[var(--color-border-dark)] rounded hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent-light)] transition-colors"
        >
          上一页
        </a>
      )}
      {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
        <a
          href={page === 1 ? baseUrl : `${baseUrl}/${page}`}
          class={`px-3 py-1.5 text-sm rounded transition-colors ${
            page === currentPage
              ? "bg-[var(--color-accent)] text-white"
              : "border border-[var(--color-border)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent-light)]"
          }`}
        >
          {page}
        </a>
      ))}
      {currentPage < totalPages && (
        <a
          href={`${baseUrl}/${currentPage + 1}`}
          class="px-3 py-1.5 text-sm border border-[var(--color-border)] dark:border-[var(--color-border-dark)] rounded hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent-light)] transition-colors"
        >
          下一页
        </a>
      )}
    </nav>
  )
}
