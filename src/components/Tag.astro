---
import { slugifyStr } from "@/utils/slugify";

export interface Props {
  tag: string;
}

const { tag } = Astro.props;
---

<a
  href={`/tags/${slugifyStr(tag)}`}
  class="inline-flex items-center px-2.5 py-0.5 text-xs font-medium rounded-full border border-border hover:border-accent hover:text-accent transition-colors"
>
  {tag}
</a>
