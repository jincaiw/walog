---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconHash from "@/assets/icons/IconHash.svg";
import { slugifyStr } from "@/utils/slugify";
import { useTranslations } from "@/i18n";
import config from "@/config";

type Props = {
  tag: string;
  tagName?: string;
  size?: "sm" | "lg";
};

const t = useTranslations(Astro.currentLocale ?? config.site.lang);
const { tag, tagName, size = "lg" } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
---

<a
  href={getRelativeLocaleUrl(locale, `tags/${slugifyStr(tag)}`)}
  class:list={[
    "tag-link border-border hover:border-accent flex items-center gap-1 border font-medium no-underline",
    size === "sm"
      ? "rounded px-2 py-0.5 text-[0.7rem]"
      : "rounded-full px-4 py-1.5 text-sm",
    "focus-visible:outline-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-dashed",
  ]}
  aria-label={`${t.post.tagLabel} - ${tagName ?? tag}`}
>
  <IconHash
    class:list={[
      size === "sm" ? "size-3" : "size-4",
    ]}
    aria-hidden="true"
  />
  {tagName ?? tag}
</a>
