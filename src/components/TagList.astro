---
export interface Props {
  tags: { tag: string; count: number }[];
}

const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {tags.map(({ tag, count }) => (
    <a
      href={`/tags/${encodeURIComponent(tag)}`}
      class="inline-flex items-center gap-1 px-3 py-1 text-sm rounded-full border border-[var(--color-border)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent-light)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-light)] transition-colors"
    >
      {tag}
      <span class="text-xs text-[var(--color-text-secondary)] dark:text-[var(--color-text-dark-secondary)]">({count})</span>
    </a>
  ))}
</div>
