---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
---

<Layout title="页面未找到" description="找不到你要查看的页面">
  <Header />

  <div class="mx-auto max-w-[780px] px-4 sm:px-6 pt-20 pb-24 text-center flex-1">
    <h1 class="text-5xl font-bold text-accent mb-4">404</h1>
    <p class="text-lg text-muted-foreground mb-8">找不到你要查看的页面。</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <LinkButton href="/" variant="primary">返回首页</LinkButton>
      <LinkButton href="/posts">查看文章</LinkButton>
      <LinkButton href="/search">搜索</LinkButton>
    </div>
  </div>

  <Footer />
</Layout>
