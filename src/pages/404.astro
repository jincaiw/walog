---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import { useTranslations } from "@/i18n";
import config from "@/config";
import { getRelativeLocaleUrl } from "astro:i18n";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<Layout title={`${t.notFound.title} | ${config.site.title}`}>
  <Header />

  <main class="app-layout flex flex-col items-center justify-center py-24">
    <h1 class="text-accent mb-4 text-6xl font-bold">404</h1>
    <p class="mb-8 text-xl">{t.notFound.message}</p>
    <LinkButton
      href={getRelativeLocaleUrl(locale, "")}
      class="hover:text-accent hover:border-accent border-border rounded border px-4 py-2 text-sm font-medium"
    >
      {t.notFound.goHome}
    </LinkButton>
  </main>

  <Footer />
</Layout>
