---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import config from "@/config";
---

<Layout title="关于">
  <Header />

  <Main pageTitle="关于">
    <div class="prose prose-neutral dark:prose-invert max-w-[780px]">
      <p>这是 <strong>{config.site.title}</strong>。</p>
      <p>这里记录日常生活、想法、脑洞和各种思考。</p>
      <p>博客使用 Astro 构建，部署于 GitHub Pages。</p>
      <h2>联系方式</h2>
      <ul>
        <li>GitHub：<a href={config.site.profile ?? "https://github.com/jincaiw"} target="_blank" rel="noopener noreferrer">{config.site.profile ?? "https://github.com/jincaiw"}</a></li>
        <li>RSS：<a href={new URL("/rss.xml", Astro.site).href}>订阅更新</a></li>
      </ul>
    </div>
  </Main>

  <Footer />
</Layout>
