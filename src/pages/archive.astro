---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getCollection } from "astro:content";
import { groupPostsByYear, getPostUrl, formatDate } from "@/utils";

const allPosts = await getCollection("blog");
const grouped = groupPostsByYear(allPosts);
const years = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="归档">
  <Fragment slot="header"><Header /></Fragment>

  <div class="mx-auto max-w-[1120px] px-4 sm:px-6 pt-12 pb-16">
    <h1 class="text-2xl font-bold mb-8">归档</h1>
    {years.map((year) => (
      <div class="mb-8">
        <h2 class="text-xl font-semibold mb-4 text-[var(--color-accent)]">{year}</h2>
        <div class="space-y-2">
          {grouped[Number(year)].map((post) => (
            <div class="flex items-baseline gap-3">
              <time class="text-sm text-[var(--color-text-secondary)] dark:text-[var(--color-text-dark-secondary)] shrink-0 w-16 tabular-nums">
                {formatDate(post.data.publishDate)}
              </time>
              <a href={getPostUrl(post)} class="text-sm hover:text-[var(--color-accent)] transition-colors">
                {post.data.title}
              </a>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>
