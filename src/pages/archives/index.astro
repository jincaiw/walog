---
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostsByGroupCondition } from "./_utils/getPostsByGroupCondition";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const yearPosts = getPostsByGroupCondition(sortedPosts);

const currentTimezone = config.site.timezone ?? "UTC";
---

<Layout title={`${t.pages.archivesTitle} | ${config.site.title}`}>
  <Header />

  <Main pageTitle={t.pages.archivesTitle} pageDesc={t.pages.archivesDesc}>
    {Array.from(yearPosts).map(([year, posts]) => (
      <details class="mb-4" open>
        <summary class="text-accent mb-2 cursor-pointer text-lg font-semibold">
          {year} — ({posts.length} {posts.length > 1 ? "posts" : "post"})
        </summary>
        <ul>
          {posts.map(({ data, id }) => (
            <li class="my-2 flex items-baseline gap-2">
              <time class="text-muted-foreground shrink-0 text-sm italic tabular-nums">
                {dayjs(data.pubDatetime)
                  .tz(currentTimezone)
                  .format("MMM DD")}
              </time>
              <a
                href={`/posts/${id}`}
                class="hover:text-accent decoration-dashed underline-offset-4 hover:underline"
              >
                {data.title}
              </a>
            </li>
          ))}
        </ul>
      </details>
    ))}
  </Main>

  <Footer />
</Layout>
