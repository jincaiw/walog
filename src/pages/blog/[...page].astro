---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import Pagination from "@/components/Pagination.astro";
import { getCollection } from "astro:content";
import { getPaginatedPosts } from "@/utils";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const { totalPages } = getPaginatedPosts(allPosts, 1);

  return [
    { params: { page: undefined }, props: { page: 1 } },
    ...Array.from({ length: totalPages - 1 }, (_, i) => ({
      params: { page: String(i + 2) },
      props: { page: i + 2 },
    })),
  ];
}

const { page } = Astro.props;
const allPosts = await getCollection("blog");
const { posts, totalPages, currentPage } = getPaginatedPosts(allPosts, page);
---

<BaseLayout title={currentPage === 1 ? "文章" : `文章 — 第 ${currentPage} 页`}>
  <Fragment slot="header"><Header /></Fragment>

  <div class="mx-auto max-w-[1120px] px-4 sm:px-6 pt-12 pb-16">
    <h1 class="text-2xl font-bold mb-8">文章</h1>
    <div class="space-y-7">
      {posts.map((post) => <ArticleCard post={post} />)}
    </div>
    <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/blog" />
  </div>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>
