---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { siteConfig } from "@/config";
import { getCollection } from "astro:content";
import type { Post } from "@/utils";
import { getPublishedPosts, getPostSlug, getPostUrl, getReadingTime, formatDate, getAdjacentPosts } from "@/utils";
import { render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return getPublishedPosts(posts).map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { slug: getPostSlug(post) },
  }));
}

const { slug } = Astro.props;
const allPosts = await getCollection("blog");
const post = allPosts.find((p: Post) => getPostSlug(p) === slug)!;
const { Content, headings } = await render(post);
// Estimate reading time from rendered HTML text length
const readingText = headings?.map((h: { text: string }) => h.text).join(" ") ?? post.data.description;
const readingTime = getReadingTime(readingText + " " + post.data.description);
const { prev, next } = getAdjacentPosts(allPosts, slug);

// Extract headings for TOC
const tocHeadings = headings?.filter((h: { depth: number }) => h.depth >= 2 && h.depth <= 3) ?? [];
const showToc = tocHeadings.length >= 4;

const pageTitle = post.data.title;
const pageDesc = post.data.description;
const ogImage = post.data.cover ? post.data.cover : undefined;
const canonical = post.data.canonicalUrl ? post.data.canonicalUrl : undefined;
---

<BaseLayout title={pageTitle} description={pageDesc} ogImage={ogImage} canonicalUrl={canonical}>
  <Fragment slot="header"><Header /></Fragment>

  <article class="mx-auto max-w-[1120px] px-4 sm:px-6 pt-12 pb-16">
    <div class="flex gap-8">
      <!-- Main content -->
      <div class="flex-1 min-w-0">
        <header class="mb-8">
          <h1 class="text-2xl sm:text-3xl font-bold leading-tight mb-4">{post.data.title}</h1>
          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[var(--color-text-secondary)] dark:text-[var(--color-text-dark-secondary)]">
            <time datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
            {post.data.updatedDate && (
              <span>更新于 <time datetime={post.data.updatedDate.toISOString()}>{formatDate(post.data.updatedDate)}</time></span>
            )}
            <span>{readingTime} 分钟阅读</span>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="flex items-center gap-1.5">
                {post.data.tags.map((tag: string) => (
                  <a href={`/tags/${encodeURIComponent(tag)}`} class="px-2 py-0.5 rounded bg-[var(--color-bg-alt)] dark:bg-[var(--color-bg-alt-dark)] hover:text-[var(--color-accent)] transition-colors">{tag}</a>
                ))}
              </div>
            )}
          </div>
        </header>

        <div class="prose" data-pagefind-body>
          <Content />
        </div>

        <!-- Adjacent posts -->
        <nav class="mt-12 pt-6 border-t border-[var(--color-border)] dark:border-[var(--color-border-dark)] grid grid-cols-1 sm:grid-cols-2 gap-4">
          {next && (
            <a href={getPostUrl(next)} class="group">
              <span class="text-xs text-[var(--color-text-secondary)] dark:text-[var(--color-text-dark-secondary)]">← 下一篇</span>
              <p class="text-sm font-medium group-hover:text-[var(--color-accent)] transition-colors mt-1">{next.data.title}</p>
            </a>
          )}
          {prev && (
            <a href={getPostUrl(prev)} class="group sm:text-right">
              <span class="text-xs text-[var(--color-text-secondary)] dark:text-[var(--color-text-dark-secondary)]">上一篇 →</span>
              <p class="text-sm font-medium group-hover:text-[var(--color-accent)] transition-colors mt-1">{prev.data.title}</p>
            </a>
          )}
        </nav>

        <!-- Giscus (optional) -->
        {siteConfig.giscus.repo && (
          <div class="mt-12 pt-6 border-t border-[var(--color-border)] dark:border-[var(--color-border-dark)]">
            <div id="giscus-comments"></div>
            <script>
              (function() {
                const giscus = document.createElement('script');
                giscus.src = 'https://giscus.app/client.js';
                giscus.setAttribute('data-repo', '${siteConfig.giscus.repo}');
                giscus.setAttribute('data-repo-id', '${siteConfig.giscus.repoId}');
                giscus.setAttribute('data-category', '${siteConfig.giscus.category}');
                giscus.setAttribute('data-category-id', '${siteConfig.giscus.categoryId}');
                giscus.setAttribute('data-mapping', 'pathname');
                giscus.setAttribute('data-strict', '0');
                giscus.setAttribute('data-reactions-enabled', '1');
                giscus.setAttribute('data-emit-metadata', '0');
                giscus.setAttribute('data-input-position', 'bottom');
                giscus.setAttribute('data-theme', 'preferred_color_scheme');
                giscus.setAttribute('data-lang', 'zh-CN');
                giscus.setAttribute('crossorigin', 'anonymous');
                giscus.setAttribute('data-loading', 'lazy');
                document.getElementById('giscus-comments')?.appendChild(giscus);
              })();
            </script>
          </div>
        )}
      </div>

      <!-- TOC sidebar -->
      {showToc && (
        <aside class="hidden lg:block w-56 shrink-0">
          <div class="sticky top-20">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-secondary)] dark:text-[var(--color-text-dark-secondary)] mb-3">目录</h3>
            <nav class="space-y-1 text-sm">
              {tocHeadings.map((h: { slug: string; depth: number; text: string }) => (
                <a
                  href={`#${h.slug}`}
                  class={`block py-1 text-[var(--color-text-secondary)] dark:text-[var(--color-text-dark-secondary)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-light)] transition-colors no-underline ${
                    h.depth === 3 ? "pl-4" : ""
                  }`}
                >
                  {h.text}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </div>
  </article>

  <!-- Code copy button -->
  <script>
    document.querySelectorAll("pre").forEach((pre) => {
      const wrapper = document.createElement("div");
      wrapper.className = "code-toolbar";
      pre.parentNode!.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const btn = document.createElement("button");
      btn.className = "copy-btn";
      btn.textContent = "复制";
      wrapper.appendChild(btn);

      btn.addEventListener("click", async () => {
        const code = pre.querySelector("code");
        if (!code) return;
        try {
          await navigator.clipboard.writeText(code.textContent ?? "");
          btn.textContent = "已复制";
          btn.classList.add("copied");
          setTimeout(() => {
            btn.textContent = "复制";
            btn.classList.remove("copied");
          }, 2000);
        } catch {
          btn.textContent = "复制失败";
        }
      });
    });
  </script>

  <!-- Back to top -->
  <button id="back-to-top" class="back-to-top" aria-label="返回顶部">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>
  <script>
    const backToTop = document.getElementById("back-to-top")!;
    const toggleBackToTop = () => {
      backToTop.classList.toggle("visible", window.scrollY > 400);
    };
    window.addEventListener("scroll", toggleBackToTop, { passive: true });
    backToTop.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  </script>

  <!-- JSON-LD -->
  <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": {JSON.stringify(post.data.title)},
      "description": {JSON.stringify(post.data.description)},
      "datePublished": {JSON.stringify(post.data.publishDate.toISOString())},
      {post.data.updatedDate ? `"dateModified": ${JSON.stringify(post.data.updatedDate.toISOString())},` : ""}
      "author": {
        "@type": "Person",
        "name": {JSON.stringify(post.data.author ?? siteConfig.author)}
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": {JSON.stringify(new URL(getPostUrl(post), Astro.site).href)}
      }
    }
  </script>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>
