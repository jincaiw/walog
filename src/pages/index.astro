---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { siteConfig } from "@/config";
import { getCollection } from "astro:content";
import { getPublishedPosts, sortPostsByDate, getFeaturedPosts, getAllTags } from "@/utils";

const allPosts = await getCollection("blog");
const publishedPosts = sortPostsByDate(getPublishedPosts(allPosts));
const featuredPosts = getFeaturedPosts(allPosts);
const recentPosts = publishedPosts.slice(0, 5);
const tags = getAllTags(allPosts).slice(0, 10);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <Fragment slot="header"><Header /></Fragment>

  <!-- Hero -->
  <section class="mx-auto max-w-[1120px] px-4 sm:px-6 pt-16 pb-10">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3">{siteConfig.title}</h1>
    <p class="text-base text-[var(--color-text-secondary)] dark:text-[var(--color-text-dark-secondary)] max-w-lg">{siteConfig.description}</p>
  </section>

  <!-- Featured posts -->
  {featuredPosts.length > 0 && (
    <section class="mx-auto max-w-[1120px] px-4 sm:px-6 pb-8">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-secondary)] dark:text-[var(--color-text-dark-secondary)] mb-4">精选文章</h2>
      <div class="space-y-5">
        {featuredPosts.map((post) => <ArticleCard post={post} />)}
      </div>
    </section>
  )}

  <!-- Recent posts -->
  <section class="mx-auto max-w-[1120px] px-4 sm:px-6 pb-8">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-secondary)] dark:text-[var(--color-text-dark-secondary)] mb-4">最新文章</h2>
    <div class="space-y-5">
      {recentPosts.map((post) => <ArticleCard post={post} />)}
    </div>
    {publishedPosts.length > siteConfig.postsPerPage && (
      <a href="/blog" class="inline-block mt-6 text-sm text-[var(--color-accent)] hover:underline">查看所有文章 →</a>
    )}
  </section>

  <!-- Tags -->
  <section class="mx-auto max-w-[1120px] px-4 sm:px-6 pb-16">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-secondary)] dark:text-[var(--color-text-dark-secondary)] mb-4">常用标签</h2>
    <div class="flex flex-wrap gap-2">
      {tags.map(({ tag, count }) => (
        <a
          href={`/tags/${encodeURIComponent(tag)}`}
          class="inline-flex items-center gap-1 px-3 py-1 text-sm rounded-full border border-[var(--color-border)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent-light)] hover:text-[var(--color-accent)] transition-colors"
        >
          {tag}<span class="text-xs text-[var(--color-text-secondary)] dark:text-[var(--color-text-dark-secondary)]">({count})</span>
        </a>
      ))}
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>
