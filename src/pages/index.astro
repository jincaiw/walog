---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import config from "@/config";
import { getCollection } from "astro:content";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { slugifyStr } from "@/utils/slugify";

const allPosts = await getCollection("posts");
const sortedPosts = getSortedPosts(allPosts);
const featuredPosts = sortedPosts.filter((p) => p.data.featured);
const recentPosts = sortedPosts.slice(0, config.posts.perIndex);
const allTags = [...new Set(allPosts.flatMap((p: { data: { tags: string[] } }) => p.data.tags))].sort();
---

<Layout>
  <Header />

  <div class="mx-auto max-w-[1120px] px-4 sm:px-6 pt-16 pb-16 flex-1 w-full">
    <section class="mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3">{config.site.title}</h1>
      <p class="text-base text-muted-foreground max-w-lg">{config.site.description}</p>
    </section>

    {featuredPosts.length > 0 && (
      <section class="mb-10">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground mb-4">精选</h2>
        <ul class="space-y-1">
          {featuredPosts.map((post) => <Card post={post} />)}
        </ul>
      </section>
    )}

    <section class="mb-10">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">最新</h2>
        <a href="/posts" class="text-sm text-accent hover:underline">查看全部</a>
      </div>
      <ul class="space-y-1">
        {recentPosts.map((post) => <Card post={post} />)}
      </ul>
    </section>

    <section class="mb-10">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground mb-4">标签</h2>
      <div class="flex flex-wrap gap-2">
        {allTags.map((tag) => (
          <a
            href={`/tags/${slugifyStr(tag as string)}`}
            class="inline-flex items-center px-3 py-1 text-sm rounded-full border border-border hover:border-accent hover:text-accent transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
    </section>
  </div>

  <Footer />
</Layout>
