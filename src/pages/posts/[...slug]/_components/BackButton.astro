---
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

{config.features.showBackButton && (
  <nav class="app-layout mt-8 mb-4">
    <a
      href="javascript:history.back()"
      class="hover:text-accent group flex items-center gap-2 text-sm font-medium"
      aria-label={t.post.goBack}
    >
      <IconArrowLeft class="size-4 rtl:-rotate-180" />
      <span>{t.post.goBack}</span>
    </a>
  </nav>
)}
