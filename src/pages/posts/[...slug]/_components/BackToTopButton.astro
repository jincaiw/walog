---
import IconArrowNarrowUp from "@/assets/icons/IconArrowNarrowUp.svg";
import { useTranslations } from "@/i18n";
import config from "@/config";

const t = useTranslations(Astro.currentLocale ?? config.site.lang);
---

<a
  href="#"
  aria-label={t.post.backToTop}
  title={t.post.backToTop}
  class="hover:text-accent flex items-center gap-1 text-sm"
  onclick="window.scrollTo({ top: 0, behavior: 'smooth' }); return false;"
>
  <IconArrowNarrowUp class="size-5" aria-hidden="true" />
  {t.post.backToTop}
</a>
