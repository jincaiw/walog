---
import PostLayout from "@/layouts/PostLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";
import BackToTopButton from "./_components/BackToTopButton.astro";
import { getCollection, render } from "astro:content";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { slugifyStr } from "@/utils/slugify";
import { getReadingTime } from "@/utils/readingTime";

export async function getStaticPaths() {
  const allPosts = await getCollection("posts");
  return getSortedPosts(allPosts).map((post) => ({
    params: { slug: slugifyStr(post.data.title) },
    props: { slug: slugifyStr(post.data.title) },
  }));
}

const { slug } = Astro.props;
const allPosts = await getCollection("posts");
const post = allPosts.find((p: { data: { title: string } }) => slugifyStr(p.data.title) === slug)!;

if (!post) {
  return Astro.rewrite("/404");
}

const { Content, headings } = await render(post) as { Content: any; headings: { slug: string; depth: number; text: string }[] };

// Calculate reading time from rendered text
const bodyText = headings?.map((h: { text: string }) => h.text).join(" ") ?? post.data.description;
const readingTime = getReadingTime(bodyText + " " + post.data.description);

const sortedPosts = getSortedPosts(allPosts);
const index = sortedPosts.findIndex((p) => slugifyStr(p.data.title) === slug);
const prev = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;
const next = index > 0 ? sortedPosts[index - 1] : null;

const tocHeadings = headings?.filter((h: { depth: number }) => h.depth >= 2 && h.depth <= 3) ?? [];
const showToc = tocHeadings.length >= 4;
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDatetime={post.data.pubDatetime}
  modDatetime={post.data.modDatetime}
>
  <Header />

  <article class="mx-auto max-w-[1120px] px-4 sm:px-6 pt-12 pb-16 flex-1 w-full">
    <div class="flex gap-8">
      <div class="flex-1 min-w-0 max-w-[780px]">
        <header class="mb-8">
          <h1 class="text-2xl sm:text-3xl font-bold leading-tight mb-4">{post.data.title}</h1>
          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted-foreground">
            <Datetime datetime={post.data.pubDatetime} />
            <span>{readingTime} 分钟阅读</span>
            {post.data.modDatetime && (
              <span>更新于 <Datetime datetime={post.data.modDatetime} /></span>
            )}
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="flex items-center gap-1.5">
                {post.data.tags.map((tag: string) => <Tag tag={tag} />)}
              </div>
            )}
          </div>
        </header>

        <div class="prose prose-neutral dark:prose-invert max-w-none" data-pagefind-body>
          <Content />
        </div>

        <nav class="mt-12 pt-6 border-t border-border grid grid-cols-1 sm:grid-cols-2 gap-4">
          {next && (
            <a href={`/posts/${slugifyStr(next.data.title)}`} class="group">
              <span class="text-xs text-muted-foreground">← 下一篇</span>
              <p class="text-sm font-medium group-hover:text-accent transition-colors mt-1">{next.data.title}</p>
            </a>
          )}
          {prev && (
            <a href={`/posts/${slugifyStr(prev.data.title)}`} class="group sm:text-right">
              <span class="text-xs text-muted-foreground">上一篇 →</span>
              <p class="text-sm font-medium group-hover:text-accent transition-colors mt-1">{prev.data.title}</p>
            </a>
          )}
        </nav>
      </div>

      {showToc && (
        <aside class="hidden lg:block w-56 shrink-0">
          <div class="sticky top-20">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-3">目录</h3>
            <nav class="space-y-1 text-sm">
              {tocHeadings.map((h: { slug: string; depth: number; text: string }) => (
                <a
                  href={`#${h.slug}`}
                  class={`block py-1 text-muted-foreground hover:text-accent transition-colors no-underline ${h.depth === 3 ? "pl-4" : ""}`}
                >
                  {h.text}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </div>
  </article>

  <script>
    document.querySelectorAll("pre").forEach((pre) => {
      const wrapper = document.createElement("div");
      wrapper.className = "relative";
      pre.parentNode!.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const btn = document.createElement("button");
      btn.className =
        "absolute top-2 right-2 px-2 py-1 text-xs text-muted-foreground bg-muted border border-border rounded opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer hover:text-accent";
      btn.textContent = "复制";
      wrapper.appendChild(btn);

      btn.addEventListener("click", async () => {
        const code = pre.querySelector("code");
        if (!code) return;
        try {
          await navigator.clipboard.writeText(code.textContent ?? "");
          btn.textContent = "已复制";
          setTimeout(() => {
            btn.textContent = "复制";
          }, 2000);
        } catch {
          btn.textContent = "复制失败";
        }
      });
    });
  </script>

  <BackToTopButton />
  <Footer />
</PostLayout>
