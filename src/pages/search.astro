---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<Layout title={`${t.pages.searchTitle} | ${config.site.title}`}>
  <Header />

  <Main pageTitle={t.pages.searchTitle} pageDesc={t.pages.searchDesc}>
    <div id="search" class="mt-4">
      {config.features.search === "pagefind" ? (
        <div id="search" />
      ) : (
        <p class="text-muted-foreground">Search is not available.</p>
      )}
    </div>
  </Main>

  {config.features.search === "pagefind" && (
    <link
      rel="stylesheet"
      href="/pagefind/pagefind-ui.css"
    />
  )}

  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const searchElement = document.querySelector("#search");
    if (searchElement) {
      import("@pagefind/default-ui").then((mod) => {
        const PagefindUI = mod.default || mod.PagefindUI;
        if (PagefindUI) {
          new PagefindUI({
            element: "#search",
            showSubResults: true,
            showImages: false,
            resetStyles: false,
          });
        }
      });
    }
  });
</script>
