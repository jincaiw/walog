---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { slugifyAll } from "@/utils/slugify";
import { useTranslations } from "@/i18n";
import config from "@/config";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("posts");
  const sortedPosts = getSortedPosts(posts);
  const tags = [
    ...new Set(sortedPosts.flatMap((post) => slugifyAll(post.data.tags))),
  ];

  return tags.flatMap((tag) => {
    const filteredPosts = sortedPosts.filter((post) =>
      slugifyAll(post.data.tags).includes(tag),
    );
    return paginate(filteredPosts, {
      pageSize: config.posts.perPage,
      params: { tag },
      props: { tag },
    });
  });
}) satisfies GetStaticPaths;

const { page, tag } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<Layout
  title={`${t.pages.tagTitle}: ${tag} | ${config.site.title}`}
  description={`${t.pages.tagDesc}: ${tag}`}
>
  <Header />

  <Main
    pageTitle={`${t.pages.tagTitle}: ${tag}`}
    pageDesc={`${t.pages.tagDesc}: ${tag}`}
  >
    <ul>
      {page.data.map((data) => (
        <Card {...data} />
      ))}
    </ul>
  </Main>

  <Pagination page={page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
