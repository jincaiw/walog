---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import { getCollection } from "astro:content";
import { getUniqueTags } from "@/utils/getUniqueTags";

const allPosts = await getCollection("posts");
const tags = getUniqueTags(allPosts);
---

<Layout title="标签">
  <Header />

  <Main pageTitle="标签" pageDesc="按标签浏览文章">
    <div class="flex flex-wrap gap-3">
      {tags.map(({ tag, tagSlug, count }) => (
        <a
          href={`/tags/${tagSlug}`}
          class="inline-flex items-center gap-2 px-4 py-2 text-sm rounded-full border border-border hover:border-accent hover:text-accent transition-colors"
        >
          {tag}
          <span class="text-xs text-muted-foreground">({count})</span>
        </a>
      ))}
    </div>
  </Main>

  <Footer />
</Layout>
